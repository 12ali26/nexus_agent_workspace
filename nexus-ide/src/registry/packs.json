{
  "version": "3.0.0",
  "source": "local",
  "extensions": [
    {
      "id": "data-tools",
      "name": "Tables & Charts",
      "description": "Tables, charts and file loading for any data analysis work",
      "version": "0.1.0",
      "author": "NEXUS Core",
      "capabilities": [
        "table.render",
        "chart.render",
        "csv.load",
        "json.load",
        "stats.describe",
        "regression.run"
      ],
      "primitives": ["table", "chart", "stats-block", "regression"],
      "installed": false
    },
    {
      "id": "math-tools",
      "name": "Equations & Formulas",
      "description": "Equation rendering and formula evaluation",
      "version": "0.1.0",
      "author": "NEXUS Core",
      "capabilities": ["equation.render", "formula.evaluate"],
      "primitives": ["equation"],
      "installed": false
    },
    {
      "id": "code-tools",
      "name": "Code Editor & Terminal",
      "description": "Multi-language code editor and terminal output",
      "version": "0.1.0",
      "author": "NEXUS Core",
      "capabilities": [
        "javascript.run",
        "python.run",
        "r.run",
        "sql.run",
        "terminal.open"
      ],
      "primitives": ["code-editor", "terminal-output"],
      "installed": false
    },
    {
      "id": "3d-tools",
      "name": "3D Viewer & Annotations",
      "description": "3D object rendering and spatial annotation",
      "version": "0.1.0",
      "author": "NEXUS Core",
      "capabilities": ["3d.render", "annotation.attach"],
      "primitives": ["3d-object", "annotation"],
      "installed": false
    },
    {
      "id": "audit-tools",
      "name": "Assumptions & Progress",
      "description": "Assumption flagging and progress tracking for regulated work",
      "version": "0.1.0",
      "author": "NEXUS Core",
      "capabilities": ["assumption.track", "progress.track"],
      "primitives": ["assumption-flag", "progress-step"],
      "installed": false
    },
    {
      "id": "writing-tools",
      "name": "Prose & LaTeX",
      "description": "Prose writing with live LaTeX rendering for documentation and methodology",
      "version": "0.1.0",
      "author": "NEXUS Core",
      "capabilities": ["prose.write", "latex.render", "notebook.run"],
      "primitives": ["prose-block", "notebook"],
      "installed": false
    },
    {
      "id": "simulation-tools",
      "name": "Parameters & Simulation",
      "description": "Parameter nodes and reactive formula evaluation for live simulation",
      "version": "0.1.0",
      "author": "NEXUS Core",
      "capabilities": [
        "parameter.control",
        "formula.evaluate",
        "simulation.run"
      ],
      "primitives": ["parameter-node", "formula-block"],
      "installed": false
    }
  ]
}
