{
  "name": "nexus-ide",
  "private": true,
  "version": "0.1.7",
  "description": "The universal AI computational workspace",
  "homepage": "https://github.com/12ali26/nexus_agent_workspace",
  "author": {
    "name": "NEXUS IDE",
    "email": "hello@nexus-ide.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/12ali26/nexus_agent_workspace.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:icon": "node scripts/build-icons.js",
    "lint": "eslint .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview",
    "rebuild:native": "npm rebuild better-sqlite3 node-pty",
    "start": "npm run rebuild:native && node server/index.js",
    "deploy": "npm run build && npm run start"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-md-editor": "^4.1.1",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "katex": "^0.16.47",
    "lucide-react": "^1.16.0",
    "mathjs": "^15.2.0",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-rnd": "^10.5.3",
    "recharts": "^3.8.1",
    "simple-statistics": "^7.8.9",
    "three": "^0.184.0",
    "ws": "^8.21.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.34.5",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "app.nexus-ide",
    "productName": "NEXUS IDE",
    "copyright": "Copyright © 2026 NEXUS IDE",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**",
      "node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "cli/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      },
      {
        "from": "cli",
        "to": "cli"
      },
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "assets/icons",
        "to": "assets/icons"
      },
      "node_modules/node-pty/build/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "12ali26",
      "repo": "nexus_agent_workspace"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/win/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NEXUS IDE"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icons/mac/icon.icns",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "NEXUS IDE",
      "backgroundColor": "#0b0f14"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "description": "The universal AI computational workspace",
      "icon": "icons/png"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnss3",
        "libasound2t64"
      ]
    }
  }
}
